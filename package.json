{
  "name": "core-standalone-kernel",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "core:mode": "node scripts/llm-autosetup.mjs",
    "hooks:enable": "node scripts/enable-git-hooks.mjs",
    "secure:lock": "node scripts/security-lockdown.mjs",
    "secure:unlock": "node scripts/security-unlock.mjs",
    "ack:llm-entry": "node scripts/ack-llm-entry.mjs",
    "cage:init": "node scripts/core-integrity-cage.mjs init",
    "cage:check": "node scripts/core-integrity-cage.mjs check",
    "changelog:init": "node scripts/changelog-append-guard.mjs init",
    "changelog:check": "node scripts/changelog-append-guard.mjs check",
    "changelog:seal": "node scripts/changelog-append-guard.mjs seal",
    "matrix:init": "node scripts/change-matrix.mjs init",
    "matrix:record": "node scripts/change-matrix.mjs record",
    "matrix:check": "node scripts/change-matrix.mjs check",
    "trace:check": "npm run changelog:check && npm run matrix:check",
    "guard:llm": "node scripts/llm-hard-gate.mjs",
    "check:llm-entry": "node scripts/check-llm-entry.mjs",
    "check:project": "npm run guard:llm && npm run check:llm-entry && npm run trace:check && npm test",
    "test:redteam": "node tests/kernel_red_team.mjs",
    "test:stress": "node tests/kernel_stress_test.mjs",
    "test:fuzz": "node tests/kernel_stress_fuzz.mjs",
    "test:workers": "node tests/kernel_stress_worker.mjs",
    "test:replay": "node tests/kernel_persistence_replay.mjs",
    "test:determinism-sources": "node tests/kernel_determinism_sources.mjs",
    "test:system-proof": "node scripts/system-proof.mjs",
    "gate:release": "node scripts/release-gate.mjs",
    "test": "npm run guard:llm && npm run check:llm-entry && npm run trace:check && npm run test:redteam && npm run test:stress && npm run test:fuzz && npm run test:workers && npm run test:replay && npm run test:determinism-sources"
  }
}
